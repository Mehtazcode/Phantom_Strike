{
  "target": "http://localhost:3000",
  "rate_limit_ms": 0,
  "auth": {},
  "endpoints": [
    {
      "url": "http://localhost:3000/rest/user/login",
      "method": "POST",
      "body_type": "json",
      "test_params": ["email"],
      "default_params": {"email": "test@test.com", "password": "wrongpassword"},
      "extra_static_params": {}
    }
  ],
  "noise_patterns": [
    "\"token\":\"[^\"]+\""
  ]
}
